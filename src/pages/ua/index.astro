---
import Home from '@componentes/BentoGrid.astro';
import Layout from '@layouts/Layout.astro';
import { t } from '@i18n/utils';
import { getLanguageFromPath } from '@i18n/config';

const lang = getLanguageFromPath(Astro.url.pathname);
const title = t(lang, 'site.title');
const description = t(lang, 'site.description');
---

<Layout title={title} description={description}>
	<Home />
</Layout>
