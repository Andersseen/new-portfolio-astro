---
export const prerender = false;

import Layout from "@layouts/Layout.astro";
---

<Layout title="Page not found" description="Sorry, the page you are looking for does not exist.">
  <section
    class="min-h-[60vh] flex items-center justify-center px-4 py-16"
    aria-labelledby="not-found-title"
  >
    <div
      class="w-full max-w-xl text-center bg-background-secondary border border-border rounded-2xl p-8 sm:p-12 shadow-sm"
    >
      <p class="text-6xl sm:text-8xl font-bold text-primary mb-4" aria-hidden="true">
        404
      </p>
      <h1
        id="not-found-title"
        class="text-2xl sm:text-3xl font-bold text-foreground mb-3"
      >
        Page not found
      </h1>
      <p class="text-foreground-secondary mb-8">
        Sorry, the page you are looking for does not exist.
      </p>
      <a
        href="/"
        class="inline-flex items-center justify-center px-6 py-3 rounded-lg bg-primary-500 text-background font-medium hover:bg-primary-600 transition-colors"
      >
        Go back home
      </a>
    </div>
  </section>
</Layout>
