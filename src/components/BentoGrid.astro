---
import { t } from '../i18n/utils';
import { getLanguageFromPath } from '../i18n/config';
import PortfolioGrid from './PortfolioGrid';
import { getPortfolioItems } from '../data/portfolio';
import { fetchMediumArticles } from "../utils/fetchers";

const lang = getLanguageFromPath(Astro.url.pathname);
const tr = (key: string) => t(lang, key);

const mediumArticles = await fetchMediumArticles("@andriipap");

const initialItems = getPortfolioItems(tr, mediumArticles);
---

<section class="py-16 px-4 max-w-7xl mx-auto">
  <div class="mb-10 max-w-3xl">
    <p class="text-sm uppercase tracking-[0.2em] text-foreground font-semibold mb-3">
      {tr("portfolio.hero.role")}
    </p>
    <h1 class="text-4xl sm:text-6xl font-bold font-heading text-foreground">
      {tr("portfolio.hero.headline")}
    </h1>
    <p class="mt-4 text-lg text-foreground-secondary">
      {tr("portfolio.hero.subheadline")}
    </p>
  </div>

  <PortfolioGrid client:idle initialItems={initialItems} />
</section>
